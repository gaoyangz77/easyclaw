---
import { t, type Lang } from "../i18n/strings.ts";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = t(lang).hero;
---
<section class="hero">
  <div class="container hero-inner">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.title}</h1>
    <p class="subtitle">{c.subtitle}</p>
    <div class="hero-actions">
      <a href="#download" class="btn btn-primary">{c.ctaPrimary}</a>
      <a href="https://github.com/nicepkg/dlxai" class="btn btn-secondary" target="_blank" rel="noopener">{c.ctaSecondary}</a>
    </div>
    <p class="platform-line">{c.platformLine}</p>
  </div>
</section>

<style>
  .hero {
    padding: 140px 0 120px;
    background: var(--parchment);
  }
  .hero-inner {
    text-align: center;
    max-width: 880px;
  }
  .subtitle {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    line-height: 1.60;
    color: var(--text-secondary);
    margin: 28px auto 44px;
    max-width: 680px;
  }
  .hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .platform-line {
    font-size: 0.94rem;
    color: var(--text-tertiary);
    margin: 8px 0 0;
    letter-spacing: 0.02em;
  }
  @media (max-width: 767px) {
    .hero { padding: 80px 0 64px; }
    .subtitle { font-size: 1.06rem; margin: 20px auto 32px; }
  }
</style>
